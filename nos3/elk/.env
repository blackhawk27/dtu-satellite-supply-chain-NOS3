# ELK stack identity. Single source of truth, also read by docker-compose.yml.
# Lets multiple NOS3 stacks coexist on the same host without port/name
# collisions. RTEMS uses 9201/5602, Draco 9202/5603, Legacy 9203/5604.
COMPOSE_PROJECT_NAME=nos3-legacy
ES_PORT=9203
KIBANA_PORT=5604
NETWORK_NAME=nos3-legacy-core
