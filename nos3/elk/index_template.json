{
  "index_patterns": ["nos3-telemetry-*"],
  "priority": 500,
  "_meta": {
    "description": "NOS3 telemetry mappings. See nos3/elk/README or skill elk-telemetry for the canonical source. Apply with: curl -X PUT http://localhost:9200/_index_template/nos3-telemetry -H 'Content-Type: application/json' -d @nos3/elk/index_template.json"
  },
  "template": {
    "settings": {
      "index": {
        "number_of_shards": 1,
        "number_of_replicas": 0,
        "refresh_interval": "5s"
      }
    },
    "mappings": {
      "dynamic": true,
      "date_detection": false,
      "properties": {
        "@timestamp":            { "type": "date" },
        "@version":              { "type": "keyword" },
        "docker_ts":             { "type": "date", "format": "strict_date_optional_time||strict_date_time||yyyy-MM-dd'T'HH:mm:ss.SSSSSSSSS||yyyy-MM-dd'T'HH:mm:ss.SSSSSS||yyyy-MM-dd'T'HH:mm:ss.SSS" },
        "timestamp":             { "type": "date", "format": "epoch_millis" },
        "sim_timestamp":         { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 64 } } },
        "sim_timestamp_unix":    { "type": "double" },
        "sim_timestamp_iso":     { "type": "date" },

        "type":                  { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 256 } } },
        "subsystem":             { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 256 } } },
        "host":                  { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 256 } } },
        "path":                  { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 256 } } },
        "log_level":             { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 256 } } },
        "sim_component":         { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 256 } } },
        "sim_message":           { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 1024 } } },
        "message":               { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 1024 } } },
        "tags":                  { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 256 } } },

        "msg_id":                { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 32 } } },
        "msg_id_int":            { "type": "long" },
        "msg_name":              { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 128 } } },
        "msg_direction":         { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 32 } } },
        "pkt_type":              { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 32 } } },
        "layer":                 { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 64 } } },
        "app":                   { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 64 } } },
        "attack_app":            { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 64 } } },
        "apid":                  { "type": "long" },
        "sequence":              { "type": "long" },
        "length":                { "type": "long" },
        "sb_seq_wrap":           { "type": "boolean" },
        "sb_gap_size":           { "type": "long" },

        "evs_app_name":          { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 64 } } },
        "evs_event_id":          { "type": "long" },
        "evs_event_type_num":    { "type": "long" },
        "evs_severity":          { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 32 } } },
        "evs_message":           { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 1024 } } },
        "evs_raw":               { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 1024 } } },

        "mgr_mode":              { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 32 } } },
        "mgr_mode_num":          { "type": "long" },
        "spacecraft_mode":       { "type": "long" },
        "spacecraft_mode_name":  { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 32 } } },
        "mode_change_label":     { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 64 } } },
        "mission_event":         { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 64 } } },

        "lc_state":              { "type": "long" },
        "lc_ap_num":             { "type": "long" },
        "lc_ap_to":              { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 32 } } },
        "sci_pass_count":        { "type": "long" },

        "gps_valid":             { "type": "boolean" },
        "gps_lat":               { "type": "double" },
        "gps_lon":               { "type": "double" },
        "gps_alt":               { "type": "double" },
        "gps_ecef_x":            { "type": "double" },
        "gps_ecef_y":            { "type": "double" },
        "gps_ecef_z":            { "type": "double" },
        "gps_abs_time":          { "type": "double" },
        "gps_leap_seconds":      { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 32 } } },
        "gps_location":          { "type": "geo_point" },

        "eps_battery_mv":        { "type": "long" },
        "eps_battery_wh":        { "type": "double" },
        "eps_battery_soc_pct":   { "type": "double" },
        "eps_solar_power_w":     { "type": "double" },
        "eps_power_used_w":      { "type": "double" },
        "eps_power_balance_w":   { "type": "double" },
        "eps_solar_array_enabled": { "type": "boolean" },
        "battery_mv":            { "type": "long" },
        "solar_array_mv":        { "type": "long" },

        "rw_momentum":           { "type": "double" },
        "rw0_momentum":          { "type": "double" },
        "rw1_momentum":          { "type": "double" },
        "rw2_momentum":          { "type": "double" },
        "rw0_dev_count":         { "type": "long" },
        "rw1_dev_count":         { "type": "long" },
        "rw2_dev_count":         { "type": "long" },
        "rw0_dev_err_count":     { "type": "long" },
        "rw1_dev_err_count":     { "type": "long" },
        "rw2_dev_err_count":     { "type": "long" },
        "rw0_enabled":           { "type": "long" },
        "rw1_enabled":           { "type": "long" },
        "rw2_enabled":           { "type": "long" },
        "rw_cmd_count":          { "type": "long" },
        "rw_cmd_err_count":      { "type": "long" },

        "st_q0":                 { "type": "double" },
        "st_q1":                 { "type": "double" },
        "st_q2":                 { "type": "double" },
        "st_q3":                 { "type": "double" },
        "st_valid":              { "type": "long" },

        "imu_acc_x":             { "type": "double" },
        "imu_acc_y":             { "type": "double" },
        "imu_acc_z":             { "type": "double" },
        "imu_gyro_x":            { "type": "double" },
        "imu_gyro_y":            { "type": "double" },
        "imu_gyro_z":            { "type": "double" },

        "mag_x":                 { "type": "double" },
        "mag_y":                 { "type": "double" },
        "mag_z":                 { "type": "double" },

        "fss_alpha":             { "type": "double" },
        "fss_beta":              { "type": "double" },

        "css_x":                 { "type": "double" },
        "css_neg_x":             { "type": "double" },
        "css_y":                 { "type": "double" },
        "css_neg_y":             { "type": "double" },
        "css_neg_z":             { "type": "double" },
        "css_in_sun":            { "type": "long" },

        "t42_pos_x":             { "type": "double" },
        "t42_pos_y":             { "type": "double" },
        "t42_pos_z":             { "type": "double" },
        "t42_vel_x":             { "type": "double" },
        "t42_vel_y":             { "type": "double" },
        "t42_vel_z":             { "type": "double" },
        "t42_q0":                { "type": "double" },
        "t42_q1":                { "type": "double" },
        "t42_q2":                { "type": "double" },
        "t42_q3":                { "type": "double" },
        "t42_gyro_x":            { "type": "double" },
        "t42_gyro_y":            { "type": "double" },
        "t42_gyro_z":            { "type": "double" },
        "t42_linacc_x":          { "type": "double" },
        "t42_linacc_y":          { "type": "double" },
        "t42_linacc_z":          { "type": "double" },
        "t42_svb_x":             { "type": "double" },
        "t42_svb_y":             { "type": "double" },
        "t42_svb_z":             { "type": "double" },
        "t42_wn_x":              { "type": "double" },
        "t42_wn_y":              { "type": "double" },
        "t42_wn_z":              { "type": "double" },

        "TOTAL_CPU_PCT":         { "type": "double" },
        "CPU_PCT":               { "type": "double" },
        "NUM_PIDS":              { "type": "long" },
        "THREAD_NAME":           { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 64 } } },
        "STATUS":                { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 32 } } },
        "MEM_USED":              { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 64 } } },
        "MEM_LIMIT":             { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 64 } } },
        "hs_cpu_pct":            { "type": "double" },

        "cmd_count":             { "type": "long" },
        "cmd_err_count":         { "type": "long" },
        "rts_active_ctr":        { "type": "long" },
        "num_rts_active":        { "type": "long" },
        "curr_ats_id":           { "type": "long" },
        "hs_resets_performed":   { "type": "long" },
        "hs_failed_app":         { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 64 } } },

        "mm_poke_bits":          { "type": "long" },
        "mm_fill_bytes":         { "type": "long" },
        "mm_load_bytes":         { "type": "long" },
        "md_jam_table":          { "type": "long" },
        "md_jam_entry":          { "type": "long" },
        "md_dwell_mask":         { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 64 } } },

        "link_state":            { "type": "keyword" },
        "link_state_code":       { "type": "integer" },
        "pass_number":           { "type": "long" },
        "pass_count":            { "type": "long" },
        "elevation_deg":         { "type": "float" },
        "slant_range_km":        { "type": "float" },
        "doppler_hz":            { "type": "float" },
        "packets_downlinked":    { "type": "long" },
        "bytes_downlinked":      { "type": "long" },
        "packets_dropped":       { "type": "long" },
        "ground_station":        { "type": "keyword" },

        "nav_protocol":          { "type": "keyword" },
        "nav_msg_type":          { "type": "keyword" },
        "gnss_num_sats_gps":     { "type": "long" },
        "gnss_num_sats_glonass": { "type": "long" },
        "gnss_num_sats_galileo": { "type": "long" },
        "gnss_num_sats_beidou":  { "type": "long" },
        "gnss_num_sats_total":   { "type": "long" },
        "gnss_pdop":             { "type": "float" },
        "gnss_hdop":              { "type": "float" },
        "gnss_vdop":             { "type": "float" },
        "gnss_solution_type":      { "type": "keyword" },
        "gnss_solution_type_code": { "type": "integer" },

        "gnss_lat":              { "type": "double" },
        "gnss_lon":              { "type": "double" },
        "in_denmark_box":        { "type": "integer" },
        "in_science_mode":       { "type": "integer" },
        "last_ping_seq":         { "type": "long" },
        "last_ping_time":        { "type": "long" },
        "ping_count":            { "type": "long" }
      }
    }
  }
}
