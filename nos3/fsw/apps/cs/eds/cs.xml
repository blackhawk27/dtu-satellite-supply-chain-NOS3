<PackageFile xmlns="http://www.ccsds.org/schema/sois/seds">
  <Package name="CS" shortDescription="CFS Checksum (CS) App">
    <DataTypeSet>
      <EnumeratedDataType name="ChecksumType">
        <EnumerationList>
          <Enumeration label="CFECORE" value="0" shortDescription="cFE Core checksum" />
          <Enumeration label="OSCORE" value="1" shortDescription="OS Core checksum" />
          <Enumeration label="EEPROM_TABLE" value="2" shortDescription="EEPROM checksum" />
          <Enumeration label="MEMORY_TABLE" value="3" shortDescription="Memory checksum" />
          <Enumeration label="TABLES_TABLE" value="4" shortDescription="Tables checksum" />
          <Enumeration label="APP_TABLE" value="5" shortDescription="App checksum" />
        </EnumerationList>
        <IntegerDataEncoding sizeInBits="8" encoding="unsigned" />
      </EnumeratedDataType>

      <EnumeratedDataType name="ChecksumState">
        <EnumerationList>
          <Enumeration label="EMPTY" value="0" shortDescription="Entry unused" />
          <Enumeration label="ENABLED" value="1" shortDescription="Entry or table enabled" />
          <Enumeration label="DISABLED" value="2" shortDescription="Entry or table disabled" />
          <Enumeration label="UNDEFINED" value="3" shortDescription="Entry not found state undefined" />
        </EnumerationList>
        <IntegerDataEncoding sizeInBits="8" encoding="unsigned" />
      </EnumeratedDataType>

      <ContainerDataType name="HkPacket_Payload">
        <EntryList>
          <Entry type="BASE_TYPES/uint8" name="CmdCounter" shortDescription="CS Application Command Counter" />
          <Entry type="BASE_TYPES/uint8" name="CmdErrCounter" shortDescription="CS Application Command Error Counter" />
          <Entry type="ChecksumState" name="ChecksumState" shortDescription="CS Application global checksum state" />
          <Entry type="ChecksumState" name="EepromCSState" shortDescription="CS EEPROM table checksum state" />
          <Entry type="ChecksumState" name="MemoryCSState" shortDescription="CS Memory table checksum state" />
          <Entry type="ChecksumState" name="AppCSState" shortDescription="CS App table checksum state" />
          <Entry type="ChecksumState" name="TablesCSState" shortDescription="CS Tables table checksum state" />
          <Entry type="ChecksumState" name="OSCSState" shortDescription="OS code segment checksum state" />
          <Entry type="ChecksumState" name="CfeCoreCSState" shortDescription="cFE Core code segment checksum state" />
          <Entry type="BASE_TYPES/uint8" name="RecomputeInProgress" shortDescription="CS Recompute In Progress flag" />
          <Entry type="BASE_TYPES/uint8" name="OneShotInProgress" shortDescription="CS OneShot In Progress flag" />
          <Entry type="BASE_TYPES/uint8" name="Filler8" shortDescription="8 bit padding" />
          <Entry type="BASE_TYPES/uint16" name="EepromCSErrCounter" shortDescription="EEPROM miscompare counter" />
          <Entry type="BASE_TYPES/uint16" name="MemoryCSErrCounter" shortDescription="Memory miscompare counter" />
          <Entry type="BASE_TYPES/uint16" name="AppCSErrCounter" shortDescription="App miscompare counter" />
          <Entry type="BASE_TYPES/uint16" name="TablesCSErrCounter" shortDescription="Tables miscompare counter" />
          <Entry type="BASE_TYPES/uint16" name="CfeCoreCSErrCounter" shortDescription="cFE core miscompare counter" />
          <Entry type="BASE_TYPES/uint16" name="OSCSErrCounter" shortDescription="OS code segment miscopmare counter" />
          <Entry type="BASE_TYPES/uint16" name="CurrentCSTable" shortDescription="Current table being checksummed" />
          <Entry type="BASE_TYPES/uint16" name="CurrentEntryInTable" shortDescription="Current entry ID in table being checksummed" />
          <Entry type="BASE_TYPES/uint32" name="EepromBaseline" shortDescription="Baseline checksum for all of EEPROM" />
          <Entry type="BASE_TYPES/uint32" name="OSBaseline" shortDescription="Baseline checksum for the OS code segment" />
          <Entry type="BASE_TYPES/uint32" name="CfeCoreBaseline" shortDescription="Basline checksum for the cFE core" />
          <Entry type="BASE_TYPES/MemReference" name="LastOneShotAddress" shortDescription="Address used in last one shot checksum command" />
          <Entry type="BASE_TYPES/uint32" name="LastOneShotSize" shortDescription="Size used in the last one shot checksum command" />
          <Entry type="BASE_TYPES/uint32" name="LastOneShotMaxBytesPerCycle" shortDescription="Max bytes per cycle for last one shot checksum command" />
          <Entry type="BASE_TYPES/uint32" name="LastOneShotChecksum" shortDescription="Checksum of the last one shot checksum command" />
          <Entry type="BASE_TYPES/uint32" name="PassCounter" shortDescription="Number of times CS has passed through all of its tables" />
        </EntryList>
      </ContainerDataType>
      <ContainerDataType name="GetEntryIDCmd_Payload" shortDescription="* Get entry ID command payload">
        <EntryList>
          <Entry type="BASE_TYPES/MemReference" name="Address" shortDescription="Address to get the ID for" />
        </EntryList>
      </ContainerDataType>
      <ContainerDataType name="EntryCmd_Payload" shortDescription="* Payload for commands using Memory or EEPROM tables">
        <EntryList>
          <Entry type="BASE_TYPES/uint32" name="EntryID" shortDescription="EntryID to perform a command on" />
        </EntryList>
      </ContainerDataType>
      <ContainerDataType name="TableNameCmd_Payload" shortDescription="* Payload for commanding by table name">
        <EntryList>
          <Entry type="CFE_TBL/TableName" name="Name" shortDescription="Table name to perform a command on" />
        </EntryList>
      </ContainerDataType>
      <ContainerDataType name="AppNameCmd_Payload" shortDescription="* Payload for commanding by app name">
        <EntryList>
          <Entry type="BASE_TYPES/ApiName" name="Name" shortDescription="App name to perform a command on" />
        </EntryList>
      </ContainerDataType>
      <ContainerDataType name="OneShotCmd_Payload" shortDescription="* Payload for sending one shot calculation">
        <EntryList>
          <Entry type="BASE_TYPES/MemReference" name="Address" shortDescription="Address to start checksum" />
          <Entry type="BASE_TYPES/uint32" name="Size" shortDescription="Number of bytes to checksum" />
          <Entry type="BASE_TYPES/uint32" name="MaxBytesPerCycle" shortDescription="Max Number of bytes to compute per cycle. Value of Zero to use platform config" />
        </EntryList>
      </ContainerDataType>
      <ContainerDataType name="HkPacket" baseType="CFE_HDR/TelemetryHeader" shortDescription="Housekeeping Packet Structure">
        <EntryList>
          <Entry type="HkPacket_Payload" name="Payload" shortDescription="CS HK Payload" />
        </EntryList>
      </ContainerDataType>


      <!-- table definitions start here -->

      <ContainerDataType name="Def_EepromMemory_Table_Entry" shortDescription="Data structure for the EEPROM or Memory definition table">
        <EntryList>
          <Entry type="BASE_TYPES/MemReference" name="StartAddress" shortDescription="The Start address to Checksum" />
          <Entry type="BASE_TYPES/uint16" name="State" shortDescription="Uses the CS_STATE_... defines from above" />
          <Entry type="BASE_TYPES/uint16" name="Filler16" shortDescription="Padding" />
          <Entry type="BASE_TYPES/uint32" name="NumBytesToChecksum" shortDescription="The number of Bytes to Checksum" />
        </EntryList>
      </ContainerDataType>

      <ContainerDataType name="Res_EepromMemory_Table_Entry" shortDescription="Data structure for the Eeporom or Memory results table">
        <EntryList>
          <Entry type="BASE_TYPES/MemReference" name="StartAddress" shortDescription="The Start address to Checksum" />
          <Entry type="BASE_TYPES/uint16" name="State" shortDescription="Uses the CS_STATE_... defines from above"/>
          <Entry type="BASE_TYPES/uint16" name="ComputedYet" shortDescription="Have we computed an Integrity value yet"/>
          <Entry type="BASE_TYPES/uint32" name="NumBytesToChecksum" shortDescription="The number of Bytes to Checksum"/>
          <Entry type="BASE_TYPES/uint32" name="ComparisonValue" shortDescription="The Memory Integrity Value"/>
          <Entry type="BASE_TYPES/uint32" name="ByteOffset" shortDescription="Where a previous unfinished calc left off"/>
          <Entry type="BASE_TYPES/uint32" name="TempChecksumValue" shortDescription="The unfinished caluculation"/>
          <Entry type="BASE_TYPES/uint32" name="Filler32" shortDescription="Padding"/>
        </EntryList>
      </ContainerDataType>

      <ContainerDataType name="Def_Tables_Table_Entry" shortDescription="Data structure for the Tables definition table">
        <EntryList>
          <Entry type="BASE_TYPES/uint16" name="State" shortDescription="Uses the CS_STATE_... defines from above" />
          <Entry type="CFE_TBL/TableName" name="Name" shortDescription="name of the table" />
        </EntryList>
      </ContainerDataType>

      <ContainerDataType name="Def_App_Table_Entry" shortDescription="Data structure for the App definition table">
        <EntryList>
          <Entry type="BASE_TYPES/uint16" name="State" shortDescription="Uses the CS_STATE_... defines from above" />
          <Entry type="BASE_TYPES/ApiName" name="Name" shortDescription="name of the app" />
        </EntryList>
      </ContainerDataType>

      <ContainerDataType name="Res_Tables_Table_Entry" shortDescription="Data structure for the Tables result table">
        <EntryList>
          <Entry type="BASE_TYPES/MemReference" name="StartAddress" shortDescription="The Start address to Checksum" />
          <Entry type="BASE_TYPES/uint16" name="State" shortDescription="Uses the CS_STATE_... defines from above" />
          <Entry type="BASE_TYPES/uint16" name="ComputedYet" shortDescription="Have we computed an Integrity value yet" />
          <Entry type="BASE_TYPES/uint32" name="NumBytesToChecksum" shortDescription="The number of Bytes to Checksum" />
          <Entry type="BASE_TYPES/uint32" name="ComparisonValue" shortDescription="The Memory Integrity Value" />
          <Entry type="BASE_TYPES/uint32" name="ByteOffset" shortDescription="Where a previous unfinished calc left off" />
          <Entry type="BASE_TYPES/uint32" name="TempChecksumValue" shortDescription="The unfinished caluculation" />
          <Entry type="CFE_TBL/HandleId"  name="TblHandleID" shortDescription="handle recieved from CFE_TBL" />
          <Entry type="BASE_TYPES/uint8" name="IsCSOwner" shortDescription="Is CS the original owner of this table" />
          <Entry type="BASE_TYPES/uint8" name="Filler8" shortDescription="Padding" />
          <Entry type="CFE_TBL/TableName" name="Name" shortDescription="name of the table" />
        </EntryList>
      </ContainerDataType>

      <ContainerDataType name="Res_App_Table_Entry" shortDescription="Data structure for the app result table">
        <EntryList>
          <Entry type="BASE_TYPES/MemReference" name="StartAddress" shortDescription="The Start address to Checksum" />
          <Entry type="BASE_TYPES/uint16" name="State" shortDescription="Uses the CS_STATE_... defines from above" />
          <Entry type="BASE_TYPES/uint16" name="ComputedYet" shortDescription="Have we computed an Integrity value yet" />
          <Entry type="BASE_TYPES/uint32" name="NumBytesToChecksum" shortDescription="The number of Bytes to Checksum" />
          <Entry type="BASE_TYPES/uint32" name="ComparisonValue" shortDescription="The Memory Integrity Value" />
          <Entry type="BASE_TYPES/uint32" name="ByteOffset" shortDescription="Where a previous unfinished calc left off" />
          <Entry type="BASE_TYPES/uint32" name="TempChecksumValue" shortDescription="The unfinished caluculation" />
          <Entry type="BASE_TYPES/ApiName" name="Name" shortDescription="name of the app" />
        </EntryList>
      </ContainerDataType>

      <ArrayDataType name="Res_Eeprom_Table" dataTypeRef="Res_EepromMemory_Table_Entry" >
